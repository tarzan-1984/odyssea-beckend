# Database Configuration
# Pool size is set by the app (default connection_limit=60). Override with PRISMA_CONNECTION_LIMIT.
DATABASE_URL="postgresql://username:password@host:port/database?sslmode=require"

# Geo database (second PostgreSQL — geocoding cache, etc.)
# App default connection_limit=60. Override with GEO_PRISMA_CONNECTION_LIMIT.
GEO_DATABASE_URL="postgresql://username:password@host:port/odysseia_geo_database?sslmode=require"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-here"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Google OAuth Configuration
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# SMTP Configuration
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="your-email@gmail.com"

# Application Configuration
PORT=3001
NODE_ENV=production
API_PREFIX="/v1"
FRONTEND_URL="https://your-frontend-domain.com"

# HTTP timing logs (search Render for [HTTP][SLOW])
# HTTP_SLOW_MS=4000
# HTTP_INFO_MS=500
# HTTP_LOG_ALL=false

# Swagger Configuration
SWAGGER_TITLE="Odyssea API"
SWAGGER_DESCRIPTION="Odyssea Backend API"
SWAGGER_VERSION="1.0"

# External API Configuration
EXTERNAL_API_KEY="your-external-api-key-for-sync"

# Archive Configuration
ARCHIVE_RETENTION_MONTHS=2
