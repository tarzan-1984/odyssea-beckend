# Database Configuration
# Optional pool caps (app also sets defaults if omitted): connection_limit, pool_timeout, connect_timeout
DATABASE_URL="postgresql://username:password@host:port/database?sslmode=require&connection_limit=8&pool_timeout=20"

# Geo database (second PostgreSQL — geocoding cache, etc.)
GEO_DATABASE_URL="postgresql://username:password@host:port/odysseia_geo_database?sslmode=require&connection_limit=4&pool_timeout=20"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-here"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Google OAuth Configuration
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# SMTP Configuration
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="your-email@gmail.com"

# Application Configuration
PORT=3001
NODE_ENV=production
API_PREFIX="/v1"
FRONTEND_URL="https://your-frontend-domain.com"

# Swagger Configuration
SWAGGER_TITLE="Odyssea API"
SWAGGER_DESCRIPTION="Odyssea Backend API"
SWAGGER_VERSION="1.0"

# External API Configuration
EXTERNAL_API_KEY="your-external-api-key-for-sync"

# Archive Configuration
ARCHIVE_RETENTION_MONTHS=2
