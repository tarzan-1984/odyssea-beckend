generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  password             String?
  firstName            String
  lastName             String
  // Array of company names (e.g. ["Odysseia", "Martlet"]).
  // Prisma lists are non-nullable; default is empty array.
  company              String[]              @default([])
  phone                String?
  profilePhoto         String?
  role                 UserRole
  status               UserStatus            @default(INACTIVE)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  lastLoginAt          DateTime?
  // Last time when the mobile app entered foreground/active state.
  lastActiveApp        DateTime?             @map("last_active_app")
  // Last time when location/coordinates were updated on the mobile device (client local time as string)
  lastLocationUpdateAt String?
  // Last known coordinates of the user (from location tracking)
  latitude             Float?
  longitude            Float?
  location             String?
  city                 String?
  state                String?
  zip                  String?
  isTracking           Boolean               @default(false) @map("is_tracking")
  trackingLoadId       String?               @map("tracking_load_id")
  deactivateAccount    Boolean?              @default(false)
  externalId           String?
  type                 String?
  vin                  String?
  driverStatus         String?
  /// Average driver rating (1–5 scale). Optional.
  driverRating         Float?                @map("driver_rating")
  /// Theme / UI accent color for the user (e.g. hex #RRGGBB). Optional.
  userColor            String?               @map("user_color")
  // Date/time when driver set status (e.g. "02/11/26 2:30 PM")
  statusDate           String?
  isAutoupdate         Boolean               @default(false) @map("is_autoupdate")
  /// Mobile Settings: message push + sound (server skips push when false).
  notificationsEnabled Boolean               @default(true) @map("notifications_enabled")
  chatRooms            ChatRoomParticipant[]
  userDevices          UserDevice[]          @relation("UserDeviceByEmail")
  userDevicesByUserId  UserDevice[]          @relation("UserDeviceByUserId")
  adminOfChatRooms     ChatRoom[]            @relation("ChatRoomAdmin")
  receivedMessages     Message[]             @relation("MessageReceiver")
  sentMessages         Message[]             @relation("MessageSender")
  notifications        Notification[]
  notificationsSent    NotificationSent[]
  pushTokens           PushToken[]
  passwordResetTokens  PasswordResetToken[]
  refreshTokens        RefreshToken[]
  messageReactions     MessageReaction[]
  notificationSounds   UserNotificationSound[]
  bidRateParticipants  BidRateParticipant[]
  ownedBidRates        BidRate[]             @relation("BidRateOwner")

  @@index([externalId])
  @@index([role, isAutoupdate])
  @@map("users")
}

model UserNotificationSound {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  fileUrl   String   @map("file_url")
  key       String   @map("s3_key")
  fileName  String   @map("file_name")
  fileSize  Int?     @map("file_size")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@unique([userId, key])
  @@map("user_notification_sounds")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("otp_codes")
}

model AppSetting {
  /**
   * Singleton row (use id = "global").
   */
  id                               String   @id @default("global")
  locationMinIntervalMs            Int      @default(60000) @map("location_min_interval_ms")
  locationMinDistanceM             Int      @default(1000) @map("location_min_distance_m")
  reverseGeocodeMinDistanceM       Int      @default(5000) @map("reverse_geocode_min_distance_m")
  driverTrackingPointMinIntervalMs Int      @default(1800000) @map("driver_tracking_point_min_interval_ms")
  /**
   * Minimum seconds between TMS batch location sync runs (server cron).
   */
  tmsBatchCronIntervalSeconds      Int      @default(300) @map("tms_batch_cron_interval_seconds")
  /**
   * Max drivers per TMS batch POST request.
   */
  tmsBatchChunkSize                Int      @default(150) @map("tms_batch_chunk_size")
  /**
   * live = normal; test = only `locationTestDriverExternalId` may update location (API + TMS batch).
   */
  locationEnvironmentMode          String   @default("live") @map("location_environment_mode")
  /**
   * Allowed TMS/driver external id when mode is test (string, e.g. "3343").
   */
  locationTestDriverExternalId     String   @default("3343") @map("location_test_driver_external_id")
  /**
   * How many offers a driver may have an open bid on at once (assigned offers excluded).
   * Exposed to mobile via GET /v1/app-settings; enforced in setDriverRate.
   */
  maxDriverOpenOfferParticipations Int      @default(2) @map("max_driver_open_offer_participations")
  /**
   * Email recipient for public account deletion requests form (/delete-account).
   */
  accountDeletionRequestEmail      String   @default("") @map("account_deletion_request_email")
  /**
   * Hours after LOAD chat deliveryAt before the backend archives and deletes the chat (cron).
   */
  deliveredLoadChatArchiveAfterHours Int      @default(5) @map("delivered_load_chat_archive_after_hours")
  /**
   * Minimum mobile app marketing version (semver). Empty = no server-side force-update gate.
   * Exposed via GET /v1/app-settings; compared on device with nativeApplicationVersion.
   */
  minimumAppVersion                String   @default("") @map("minimum_app_version")
  createdAt                        DateTime @default(now()) @map("created_at")
  updatedAt                        DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  avatar    String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model NotificationSent {
  id               String   @id @default(cuid())
  userId           String
  chatRoomId       String?
  messageIds       String[]
  notificationType String
  sentAt           DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications_sent")
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String?
  deviceId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
  @@map("push_tokens")
}

/// Mobile client registry (one row per user + physical device). Push delivery still uses push_tokens.
model UserDevice {
  id             String   @id @default(cuid())
  userExternalId String
  /// Internal user id (FK to users.id; filled on mobile foreground / device register).
  userId         String?  @map("user_id")
  /// Account email at last foreground sync (FK to users.email; filled gradually).
  email          String?
  deviceId       String?
  platform       String
  appVersion     String?
  deviceName     String?
  model          String?
  osVersion      String?
  pushToken      String?
  /// Last time the app was foregrounded on this device (NY wall-clock, same encoding as users.lastActiveApp).
  lastActiveAt   DateTime? @map("last_active_at")
  /// Admin/system block flag for this installation (default not blocked).
  blocked        Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user       User? @relation("UserDeviceByEmail", fields: [email], references: [email], onDelete: SetNull, onUpdate: Cascade)
  linkedUser User? @relation("UserDeviceByUserId", fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([userExternalId, deviceId])
  @@index([userExternalId])
  @@index([userId])
  @@index([email])
  @@map("user_devices")
}

model Offer {
  id                  Int         @id @default(autoincrement())
  active              Boolean     @default(true)
  isDriverSelected    Boolean     @default(false) @map("is_driver_selected")
  externalUserId      String?     @map("external_user_id")
  loadId              String?     @map("load_id")
  createTime          String      @map("create_time")
  updateTime          String      @map("update_time")
  /// NY wall-clock time when offer was last edited via PATCH /offers/:id (nullable for legacy rows).
  updateDate          String?     @map("update_date")
  loadedMiles         Float?      @map("loaded_miles")
  offeredRate         Float?      @map("offered_rate")
  weight              Float?
  commodity           String?
  notes               String?
  specialRequirements Json?       @map("special_requirements") // array
  drivers             Json? // array
  route               Json? // array of { type: "pick_up_location"|"delivery_location", location: string, time: string }
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  rateOffers          RateOffer[]
  chatRooms           ChatRoom[]

  @@map("offers")
}

model RateOffer {
  id         Int     @id @default(autoincrement())
  offerId    Int     @map("offer_id")
  driverId   String? @map("driver_id")
  isSelected Boolean @default(false) @map("is_selected")
  rate       Float?
  actionTime BigInt? @map("action_time")
  active     Boolean @default(true)
  emptyMiles Float?  @map("empty_miles")
  totalMiles Float?  @map("total_miles")
  driverEta  String? @map("driver_eta") // Time set by driver in mobile app (Estimated Time of Arrival)
  offer      Offer   @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@map("rate_offers")
}

model BidRate {
  id           Int                  @id @default(autoincrement())
  broker       String
  rate         Float
  status       BidRateStatus        @default(in_process)
  ownerId      String               @map("owner")
  chatId       String?              @map("chat_id")
  route        Json? // array of { type: "pick_up_location"|"delivery_location", location: string, time: string }
  isArchive    Boolean              @default(false) @map("is_archive")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  owner        User                 @relation("BidRateOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  chatRoom     ChatRoom?            @relation(fields: [chatId], references: [id], onDelete: SetNull)
  participants BidRateParticipant[]

  @@index([chatId])
  @@index([ownerId])
  @@map("bid_rates")
}

model BidRateParticipant {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  externalId String   @map("external_id")
  rate       Float?
  bidRateId  Int      @map("bid_rate_id")
  /// NY wall-clock naive timestamp (set via nowInNewYorkAsNaiveDate() on insert/update).
  createdAt  DateTime @map("created_at")
  /// NY wall-clock naive timestamp (set via nowInNewYorkAsNaiveDate() on insert/update).
  updatedAt  DateTime @map("updated_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bidRate    BidRate  @relation(fields: [bidRateId], references: [id], onDelete: Cascade)

  @@unique([userId, bidRateId])
  @@index([userId])
  @@index([bidRateId])
  @@index([bidRateId, createdAt])
  @@map("bid_rate_participants")
}

model ChatRoom {
  id           String                @id @default(cuid())
  name         String?
  type         String
  loadId       String?
  offerId      Int?                  @map("offer_id")
  company      String?
  isArchived   Boolean               @default(false)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  avatar       String?
  adminId      String?               @map("admin")
  /// UTC instant when TMS ended the load: delivered, tonu, or cancelled (POST /tms/load/status).
  deliveryAt     DateTime?
  /// LOAD chat marked archived for load-specific flows (default false).
  isLoadArchived Boolean               @default(false) @map("is_load_archived")
  participants   ChatRoomParticipant[]
  admin          User?                 @relation("ChatRoomAdmin", fields: [adminId], references: [id])
  offer          Offer?                @relation(fields: [offerId], references: [id], onDelete: SetNull)
  messages       Message[]
  bidRates       BidRate[]

  /// Multiple LOAD chats per loadId are allowed (one per driver when forked from chat settings).
  @@index([loadId, type], map: "chat_rooms_load_id_type_idx")
  @@index([type, isLoadArchived, updatedAt(sort: Desc)], map: "chat_rooms_load_archived_updated_idx")
  @@index([type, isLoadArchived, deliveryAt], map: "chat_rooms_load_delivery_archive_idx")
  @@map("chat_rooms")
}

model ChatRoomParticipant {
  id              String   @id @default(cuid())
  chatRoomId      String
  userId          String
  joinedAt        DateTime @default(now())
  isHidden        Boolean  @default(false)
  mute            Boolean  @default(false)
  pin             Boolean  @default(false)
  hideParticipant Boolean  @default(false)
  unreadCount     Int      @default(0)
  chatRoom        ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatRoomId, userId])
  @@index([userId], map: "chat_room_participants_user_id_idx")
  @@index([userId, chatRoomId], map: "chat_room_participants_user_visible_idx")
  @@index([userId, isHidden, chatRoomId], map: "chat_room_participants_user_hidden_room_idx")
  @@map("chat_room_participants")
}

model Message {
  id              String   @id @default(cuid())
  chatRoomId      String
  senderId        String
  receiverId      String?
  content         String
  fileUrl         String?
  fileName        String?
  fileSize        Int?
  /// Client-generated id for idempotent send / optimistic UI (optional, mobile).
  clientMessageId String?  @map("client_message_id")
  /// Legacy: JSON array of attachments. New multi-file messages use pipe "|" inside fileUrl and fileName (same indexes).
  attachments     Json?
  createdAt       DateTime @default(now())
  readBy          Json?
  isRead          Boolean  @default(false)
  replyData       Json?
  /// TMS load chat dispatch text from POST /create_load_chat (Odysseia Team, no avatar).
  isSystemMessage Boolean  @default(false) @map("is_system_message")
  chatRoom        ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  receiver        User?    @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  sender          User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  reactions       MessageReaction[]

  @@unique([chatRoomId, clientMessageId], map: "messages_chat_room_client_message_id_key")
  @@index([chatRoomId, createdAt(sort: Desc)], map: "messages_chat_room_id_created_at_idx")
  @@index([chatRoomId, senderId], map: "messages_chat_room_id_sender_id_idx")
  @@map("messages")
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
  @@map("message_reactions")
}

/// Saved text snippets for chat, keyed by TMS / user external id.
model MessageTemplate {
  id         Int                     @id @default(autoincrement())
  externalId String
  type       MessageTemplateType     @default(personal)
  group      MessageTemplateGroup?
  title      String?
  content    String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@index([externalId])
  @@map("message_templates")
}

/// Audit log of driver profile / status changes (createdAt stored as America/New_York wall clock).
model DriverLog {
  id        String          @id @default(cuid())
  driverId  String          @map("driver_id")
  changes   String
  source    DriverLogSource
  /// NY wall-clock naive timestamp (set via nowInNewYorkAsNaiveDate() on insert).
  createdAt DateTime        @map("created_at")

  @@index([driverId])
  @@index([driverId, createdAt(sort: Desc)])
  @@map("driver_logs")
}

model DriverTracking {
  id               String   @id @default(cuid())
  externalDriverId String   @map("external_driver_id")
  loadId           String   @map("load_id")
  latitude         Float
  longitude        Float
  /// Locality snapshot at point creation (from user city/state/zip after location update / reverse geocode).
  placeLabel       String?  @map("place_label")
  /// Stable per-installation device id from the mobile client.
  deviceId         String?  @map("device_id")
  deviceModel      String?  @map("device_model")
  deviceName       String?  @map("device_name")
  devicePlatform   String?  @map("device_platform")
  updatedAt        DateTime
  createdAt        DateTime @default(now())

  @@index([externalDriverId])
  @@index([loadId])
  @@index([loadId, createdAt], map: "driver_tracking_load_id_createdAt_idx")
  @@index([externalDriverId, loadId])
  @@index([createdAt])
  @@map("driver_tracking")
}

/// Server-side Nominatim cache for TMS load pickup/delivery map markers (cleared on delivered).
model LoadRouteGeocode {
  id        String   @id @default(cuid())
  loadId    String   @unique @map("load_id")
  pickupLat Float?   @map("pickup_lat")
  pickupLng Float?   @map("pickup_lng")
  /// Label used for marker popup (query that produced the hit).
  pickupGeocodeQuery String? @map("pickup_geocode_query")
  deliveryLat        Float?   @map("delivery_lat")
  deliveryLng        Float?   @map("delivery_lng")
  deliveryGeocodeQuery String? @map("delivery_geocode_query")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("load_route_geocodes")
}

model FileObject {
  id        String   @id @default(cuid())
  key       String   @unique
  url       String
  mime      String?
  size      Int?
  userId    String?
  createdAt DateTime @default(now())
}

enum UserRole {
  DRIVER_UPDATES
  MODERATOR
  RECRUITER
  ADMINISTRATOR
  NIGHTSHIFT_TRACKING
  DISPATCHER
  BILLING
  SUBSCRIBER
  ACCOUNTING
  RECRUITER_TL
  HR_MANAGER
  TRACKING
  DISPATCHER_TL
  TRACKING_TL
  MORNING_TRACKING
  EXPEDITE_MANAGER
  DRIVER
  GAST
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

enum MessageTemplateType {
  personal
  company
}

enum MessageTemplateGroup {
  Expedite
  HR
  Tracking
}

enum DriverLogSource {
  webApp
  mobileApp
  TMS
}

enum BidRateStatus {
  blocked
  in_process @map("in-process")
  completed
}
