generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  password             String?
  firstName            String
  lastName             String
  // Array of company names (e.g. ["Odysseia", "Martlet"]).
  // Prisma lists are non-nullable; default is empty array.
  company              String[]              @default([])
  phone                String?
  profilePhoto         String?
  role                 UserRole
  status               UserStatus            @default(INACTIVE)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  lastLoginAt          DateTime?
  // Last time when location/coordinates were updated on the mobile device (client local time as string)
  lastLocationUpdateAt String?
  // Last known coordinates of the user (from location tracking)
  latitude             Float?
  longitude            Float?
  location             String?
  city                 String?
  state                String?
  zip                  String?
  deactivateAccount    Boolean?              @default(false)
  externalId           String?               @unique
  type                 String?
  vin                  String?
  driverStatus         String?
  // Date/time when driver set status (e.g. "02/11/26 2:30 PM")
  statusDate           String?
  isAutoupdate         Boolean               @default(false) @map("is_autoupdate")
  chatRooms            ChatRoomParticipant[]
  adminOfChatRooms     ChatRoom[]            @relation("ChatRoomAdmin")
  receivedMessages     Message[]             @relation("MessageReceiver")
  sentMessages         Message[]             @relation("MessageSender")
  notifications        Notification[]
  notificationsSent    NotificationSent[]
  pushTokens           PushToken[]
  passwordResetTokens  PasswordResetToken[]
  refreshTokens        RefreshToken[]
  offersCreated        Offer[]               @relation("OfferCreator")
  rateOffersAsDriver   RateOffer[]
  userDevices          UserDevice[]

  @@index([role, isAutoupdate])
  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("otp_codes")
}

model AppSetting {
  /**
   * Singleton row (use id = "global").
   */
  id                         String   @id @default("global")
  locationMinIntervalMs      Int      @default(60000) @map("location_min_interval_ms")
  locationMinDistanceM       Int      @default(1000)  @map("location_min_distance_m")
  reverseGeocodeMinDistanceM Int      @default(5000)  @map("reverse_geocode_min_distance_m")
  /** Minimum seconds between TMS batch location sync runs (server cron). */
  tmsBatchCronIntervalSeconds Int     @default(300)   @map("tms_batch_cron_interval_seconds")
  /** Max drivers per TMS batch POST request. */
  tmsBatchChunkSize          Int      @default(150)   @map("tms_batch_chunk_size")
  /**
   * live = normal; test = only `locationTestDriverExternalId` may update location (API + TMS batch).
   */
  locationEnvironmentMode      String   @default("live") @map("location_environment_mode")
  /** Allowed TMS/driver external id when mode is test (string, e.g. "3343"). */
  locationTestDriverExternalId String   @default("3343") @map("location_test_driver_external_id")
  /**
   * How many offers a driver may have an open bid on at once (assigned offers excluded).
   * Exposed to mobile via GET /v1/app-settings; enforced in setDriverRate.
   */
  maxDriverOpenOfferParticipations Int @default(2) @map("max_driver_open_offer_participations")
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt      @map("updated_at")

  @@map("app_settings")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  avatar    String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model NotificationSent {
  id               String   @id @default(cuid())
  userId           String
  chatRoomId       String?
  messageIds       String[]
  notificationType String
  sentAt           DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications_sent")
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String?
  deviceId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
  @@map("push_tokens")
}

/// Mobile client snapshot after login (analytics). Push delivery still uses push_tokens.
model UserDevice {
  id             String   @id @default(cuid())
  userExternalId String
  platform       String
  appVersion     String?
  deviceName     String?
  model          String?
  osVersion      String?
  pushToken      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userExternalId], references: [externalId], onDelete: Cascade)

  @@index([userExternalId])
  @@map("user_devices")
}

model Offer {
  id                   Int          @id @default(autoincrement())
  active               Boolean      @default(true)
  isDriverSelected     Boolean      @default(false) @map("is_driver_selected")
  externalUserId       String?      @map("external_user_id")
  loadId               String?      @map("load_id")
  createTime           String       @map("create_time")
  updateTime           String       @map("update_time")
  loadedMiles          Float?       @map("loaded_miles")
  weight               Float?
  commodity            String?
  notes                String?
  specialRequirements  Json?        @map("special_requirements") // array
  drivers              Json?        // array
  route                Json?        // array of { type: "pick_up_location"|"delivery_location", location: string, time: string }
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  creator              User?        @relation("OfferCreator", fields: [externalUserId], references: [externalId])
  rateOffers           RateOffer[]
  chatRooms            ChatRoom[]

  @@map("offers")
}

model RateOffer {
  id         Int      @id @default(autoincrement())
  offerId    Int      @map("offer_id")
  driverId   String?  @map("driver_id")
  isSelected Boolean  @default(false) @map("is_selected")
  rate       Float?
  actionTime BigInt?  @map("action_time")
  active     Boolean  @default(true)
  emptyMiles Float?   @map("empty_miles")
  totalMiles Float?   @map("total_miles")
  driverEta  String?  @map("driver_eta") // Time set by driver in mobile app (Estimated Time of Arrival)
  offer      Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  driver     User?    @relation(fields: [driverId], references: [externalId])

  @@map("rate_offers")
}

model ChatRoom {
  id           String                @id @default(cuid())
  name         String?
  type         String
  loadId       String?
  offerId      Int?                  @map("offer_id")
  company      String?
  isArchived   Boolean               @default(false)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  avatar       String?
  adminId      String?               @map("admin")
  participants ChatRoomParticipant[]
  admin        User?                 @relation("ChatRoomAdmin", fields: [adminId], references: [id])
  offer        Offer?                @relation(fields: [offerId], references: [id], onDelete: SetNull)
  messages     Message[]

  @@map("chat_rooms")
}

model ChatRoomParticipant {
  id              String   @id @default(cuid())
  chatRoomId      String
  userId          String
  joinedAt        DateTime @default(now())
  isHidden        Boolean  @default(false)
  mute            Boolean  @default(false)
  pin             Boolean  @default(false)
  hideParticipant Boolean  @default(false)
  chatRoom        ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatRoomId, userId])
  @@map("chat_room_participants")
}

model Message {
  id         String   @id @default(cuid())
  chatRoomId String
  senderId   String
  receiverId String?
  content    String
  fileUrl    String?
  fileName   String?
  fileSize   Int?
  createdAt  DateTime @default(now())
  readBy     Json?
  isRead     Boolean  @default(false)
  replyData  Json?
  chatRoom   ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  receiver   User?    @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model FileObject {
  id        String   @id @default(cuid())
  key       String   @unique
  url       String
  mime      String?
  size      Int?
  userId    String?
  createdAt DateTime @default(now())
}

enum UserRole {
  DRIVER_UPDATES
  MODERATOR
  RECRUITER
  ADMINISTRATOR
  NIGHTSHIFT_TRACKING
  DISPATCHER
  BILLING
  SUBSCRIBER
  ACCOUNTING
  RECRUITER_TL
  TRACKING
  DISPATCHER_TL
  TRACKING_TL
  MORNING_TRACKING
  EXPEDITE_MANAGER
  DRIVER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}
