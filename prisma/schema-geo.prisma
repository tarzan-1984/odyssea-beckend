// Second PostgreSQL database (geo / geocoding cache on Render).
// Add models here when the geo schema is defined, then run:
//   npx prisma db push --schema=prisma/schema-geo.prisma
generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/geo-client"
}

datasource db {
  provider = "postgresql"
  url      = env("GEO_DATABASE_URL")
}

model GeoZip {
  id          Int     @id @default(autoincrement())
  zip         String? @db.VarChar(20)
  city        String? @db.VarChar(100)
  state       String? @db.VarChar(100)
  stateCode   String? @map("state_code") @db.VarChar(10)
  countryCode String? @map("country_code") @db.VarChar(2)
  geom        Unsupported("geometry(MultiPolygon,4326)")?

  @@index([geom], type: Gist, map: "geo_zips_geom_idx")
  @@index([countryCode], map: "geo_zips_country_code_idx")
  // Partial per-country GIST indexes: prisma/sql/indexes-geo-zips-optimize.sql
  @@map("geo_zips")
}

model GeoReverseCache {
  id          Int      @id @default(autoincrement())
  gridLat     Int      @map("grid_lat")
  gridLng     Int      @map("grid_lng")
  centerLat   Float    @map("center_lat")
  centerLng   Float    @map("center_lng")
  city        String?  @db.VarChar(100)
  state       String?  @db.VarChar(100)
  stateCode   String?  @map("state_code") @db.VarChar(10)
  zip         String?  @db.VarChar(20)
  countryCode String?  @map("country_code") @db.VarChar(2)
  source      String   @default("here") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([gridLat, gridLng], map: "geo_reverse_cache_grid_uidx")
  @@map("geo_reverse_cache")
}
